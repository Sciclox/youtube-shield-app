<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/itemContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_item_bg"
    android:paddingLeft="4dp"
    android:paddingRight="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- Active Indicator (Red bar) -->
    <ImageView
        android:id="@+id/itemIndicator"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:background="@drawable/widget_item_indicator"
        android:visibility="gone"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:contentDescription="Playing Indicator" />

    <!-- Thumbnail -->
    <FrameLayout
        android:id="@+id/itemThumbnailContainer"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_toEndOf="@id/itemIndicator"
        android:layout_marginStart="8dp">

        <ImageView
            android:id="@+id/itemThumbnail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/widget_thumbnail_bg"
            android:scaleType="centerCrop"
            android:contentDescription="Thumbnail" />

        <!-- Play icon overlay for active item -->
        <ImageView
            android:id="@+id/itemPlayOverlay"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#80000000"
            android:src="@drawable/ic_play_arrow"
            android:scaleType="center"
            android:visibility="gone"
            android:contentDescription="Now Playing" />
    </FrameLayout>

    <!-- Text Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/itemThumbnailContainer"
        android:layout_marginStart="10dp"
        android:layout_centerVertical="true"
        android:orientation="vertical">

        <TextView
            android:id="@+id/itemTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFE5E2E1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.05"
            android:fontFamily="sans-serif" />

        <TextView
            android:id="@+id/itemChannel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFCBC3D7"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif" />
    </LinearLayout>

</RelativeLayout>
