<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true">

    <!-- Bubble mode (collapsed) -->
    <FrameLayout
        android:id="@+id/overlayBubble"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:visibility="visible"
        android:background="@drawable/overlay_bubble_bg"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/overlayBubbleThumbnail"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:contentDescription="Thumbnail" />

        <View
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="#80000000" />

        <ImageView
            android:id="@+id/overlayBubbleIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_play_arrow"
            android:scaleType="center"
            android:contentDescription="Play" />
    </FrameLayout>

    <!-- Expanded player mode -->
    <LinearLayout
        android:id="@+id/overlayPlayer"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="@drawable/overlay_expanded_bg"
        android:gravity="center_vertical"
        android:padding="8dp">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <ImageView
                android:id="@+id/overlayThumbnail"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:contentDescription="Thumbnail" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:id="@+id/overlayTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFE5E2E1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="YouTube Shield" />

            <TextView
                android:id="@+id/overlayChannel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFCBC3D7"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="YouTube Shield" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/overlayPlayPause"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_play_arrow"
            android:background="@drawable/widget_play_button_bg"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:contentDescription="Play/Pause" />

        <ImageButton
            android:id="@+id/overlayNext"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_skip_next"
            android:background="@null"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:layout_marginStart="4dp"
            android:contentDescription="Next" />

        <ImageButton
            android:id="@+id/overlayClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_close"
            android:background="@null"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:layout_marginStart="4dp"
            android:contentDescription="Close" />
    </LinearLayout>

</FrameLayout>
