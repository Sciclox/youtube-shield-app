<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/glass_widget_bg">

    <TextView
        android:id="@+id/glassLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REPRODUCIENDO"
        android:textSize="10sp"
        android:textColor="#9A9AB0"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/glassTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="YouTube Shield"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:fontFamily="sans-serif"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/glassChannel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:text="YouTube Shield"
        android:textSize="12sp"
        android:textColor="#C0C0D0"
        android:fontFamily="sans-serif"
        android:maxLines="1"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp">

        <ImageButton
            android:id="@+id/glassPrev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_previous"
            android:background="@null"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:contentDescription="Anterior" />

        <ImageButton
            android:id="@+id/glassPlayPause"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_play_arrow"
            android:background="@null"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:contentDescription="Play/Pause" />

        <ImageButton
            android:id="@+id/glassNext"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_next"
            android:background="@null"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:contentDescription="Siguiente" />
    </LinearLayout>

    <TextView
        android:id="@+id/glassOpenApp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Abrir YouTube Shield"
        android:textSize="11sp"
        android:textColor="#7A7AE0"
        android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="4dp" />

</LinearLayout>
