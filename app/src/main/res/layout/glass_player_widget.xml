<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/glass_widget_bg"
    android:padding="12dp">

    <!-- Now Playing Section -->
    <TextView
        android:id="@+id/glassLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REPRODUCIENDO"
        android:textSize="10sp"
        android:textColor="#9A9AB0"
        android:fontFamily="@font/outfit_variable"
        android:fontWeight="500" />

    <TextView
        android:id="@+id/glassTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="YouTube Shield"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/outfit_variable"
        android:fontWeight="700"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/glassChannel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:text="YouTube Shield"
        android:textSize="12sp"
        android:textColor="#C0C0D0"
        android:fontFamily="@font/outfit_variable"
        android:fontWeight="400"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Divider -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#30FFFFFF"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:contentDescription="Divider" />

    <!-- Playlist List -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ListView
            android:id="@+id/glassListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@null"
            android:dividerHeight="2dp"
            android:paddingTop="2dp"
            android:clipToPadding="false" />

        <LinearLayout
            android:id="@+id/glassEmptyView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No songs in playlist"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/outfit_variable"
                android:fontWeight="600"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open a YouTube video to see songs here."
                android:textColor="#C0C0D0"
                android:textSize="10sp"
                android:fontFamily="@font/outfit_variable"
                android:fontWeight="400"
                android:layout_marginTop="4dp"
                android:gravity="center" />
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="6dp">

        <ImageButton
            android:id="@+id/glassPrev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_previous"
            android:background="@null"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="Anterior" />

        <ImageButton
            android:id="@+id/glassPlayPause"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_play_arrow"
            android:background="@null"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="Play/Pause" />

        <ImageButton
            android:id="@+id/glassNext"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_next"
            android:background="@null"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Siguiente" />
    </LinearLayout>

    <!-- Open App Link -->
    <TextView
        android:id="@+id/glassOpenApp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Abrir YouTube Shield"
        android:textSize="11sp"
        android:textColor="#7A7AE0"
        android:gravity="center"
        android:fontFamily="@font/outfit_variable"
        android:fontWeight="500"
        android:layout_marginTop="4dp" />

</LinearLayout>
